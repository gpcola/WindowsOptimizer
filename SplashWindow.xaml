<Window x:Class="WindowsOptimizer.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="1LG Digital"
        Icon="Assets/App.ico"
        Width="520"
        Height="400"
        MinWidth="420"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
    <Window.Resources>
        <SolidColorBrush x:Key="BrandRedBrush" Color="#DC3545"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="1LG" FontSize="52" FontWeight="Black" HorizontalAlignment="Center"/>
                    <Border Background="{StaticResource BrandRedBrush}" Height="8" Width="96" CornerRadius="4" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="DIGITAL" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Windows Optimizer" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="A 1LG Digital utility" Foreground="{StaticResource BrandRedBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Storage analysis, safe cleanup workflows, WSL storage review, network optimisation, and recovery-aware system housekeeping." TextWrapping="Wrap" TextAlignment="Center" FontSize="15" Margin="0,0,0,18"/>
            <TextBlock Text="Website: https://www.1lg.com" TextAlignment="Center" TextWrapping="Wrap"/>
            <TextBlock Text="Email: info@1lg.com" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Center">
            <Button Content="Visit 1LG Digital" Width="150" Click="VisitWebsite_Click"/>
            <Button Content="Email 1LG" Width="110" Click="Email_Click"/>
            <Button Content="Continue" Width="110" Click="Continue_Click"/>
        </WrapPanel>
    </Grid>
</Window>
