<Window
    x:Class="WindowsOptimizer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Windows Optimizer by 1LG Digital">

    <Grid>
        <muxc:NavigationView x:Name="RootNav"
                             PaneDisplayMode="LeftCompact"
                             IsBackButtonVisible="Collapsed"
                             IsSettingsVisible="False"
                             SelectionChanged="RootNav_SelectionChanged">
            <muxc:NavigationView.Header>
                <Grid Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48" Height="48" CornerRadius="12" Background="{StaticResource BrandRedBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="1LG" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Windows Optimizer" Style="{ThemeResource TitleTextBlockStyle}" />
                        <TextBlock Text="A 1LG Digital utility - info@1lg.com - https://www.1lg.com" Opacity="0.75" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="1LG Digital" Click="Open1Lg_Click" />
                </Grid>
            </muxc:NavigationView.Header>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Home" Tag="home" />
                <muxc:NavigationViewItem Content="Optimize" Tag="optimize" />
                <muxc:NavigationViewItem Content="Storage" Tag="storage" />
                <muxc:NavigationViewItem Content="WSL Storage" Tag="wsl" />
                <muxc:NavigationViewItem Content="Network" Tag="network" />
                <muxc:NavigationViewItem Content="Restore" Tag="restore" />
                <muxc:NavigationViewItem Content="Benchmark" Tag="benchmark" />
                <muxc:NavigationViewItem Content="Advisor" Tag="advisor" />
                <muxc:NavigationViewItem Content="About 1LG" Tag="about" />
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
